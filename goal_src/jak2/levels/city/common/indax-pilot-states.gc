  :event (-> target-pilot-grab event)
  :enter (-> target-pilot-grab enter)
  :exit (-> target-pilot-grab exit)
  :code (-> target-pilot-grab code)
  :post (-> target-pilot-grab post)
  )

(defstate target-indax-pilot-clone-anim (target)
  :event (-> target-pilot-clone-anim event)
  :enter (-> target-pilot-clone-anim enter)
  :exit (-> target-pilot-clone-anim exit)
  :code (-> target-pilot-clone-anim code)
  :post (-> target-pilot-clone-anim post)
  )

(defstate target-indax-pilot-edge-grab (target)
  :event target-indax-pilot-edge-grab-event
  :enter target-indax-pilot-edge-grab-enter
  :exit (-> target-indax-edge-grab exit)
  :trans target-indax-pilot-edge-grab-trans
  :code target-indax-pilot-edge-grab-code
  :post target-indax-edge-grab-post
  )

(defstate target-indax-pilot-hit (target)
  :event (-> target-pilot-hit event)
  :exit (-> target-pilot-hit exit)
  :code (-> target-pilot-hit code)
  :post (-> target-pilot-hit post)
