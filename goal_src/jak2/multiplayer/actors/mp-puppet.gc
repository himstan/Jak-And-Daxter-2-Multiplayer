  (case (the-as mp-target-state-id (the int id))
    (((mp-target-state-id stance))      'target-stance)
    (((mp-target-state-id walk))        'target-walk)
    (((mp-target-state-id jump))        'target-jump)
    (((mp-target-state-id falling))     'target-falling)
