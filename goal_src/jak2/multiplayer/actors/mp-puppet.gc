(defun mp-puppet-update-ghost! ((ghost mp-target-ghost-record) (info remote-player-info))
  "Update the ghost record from incoming remote player info."
  (set-vector! (-> ghost trans) (-> info x) (-> info y) (-> info z) 1.0)
  (quaternion-axis-angle! (-> ghost quat) 0.0 1.0 0.0 (-> info angle)) ;; Using y-axis angle
  (vector-copy! (-> ghost velocity) (-> info velocity))
  (set! (-> ghost state-id) (-> info state-id))
  (set! (-> ghost equipped-weapon) (-> info equipped-weapon))
  (set! (-> ghost buttons) (-> info buttons))
  (set! (-> ghost leftx) (-> info leftx))
  (set! (-> ghost lefty) (-> info lefty))
  (set! (-> ghost rightx) (-> info rightx))
  (set! (-> ghost righty) (-> info righty))
  (set! (-> ghost last-update) (-> *display* game-clock frame-counter))
  (set! (-> ghost active?) #t)
  (none)
  )

(defun mp-puppet-update-pad ((pad cpad-info) (buttons uint) (lx uint) (ly uint) (rx uint) (ry uint))
  "Manually update a cpad-info structure with raw input data, shifting history and calculating derived fields."
  ;; 1. Shift history (Old values)
  (set! (-> pad old-leftx 1) (-> pad old-leftx 0))
  (set! (-> pad old-leftx 0) (-> pad leftx))
  (set! (-> pad old-lefty 1) (-> pad old-lefty 0))
  (set! (-> pad old-lefty 0) (-> pad lefty))
  (set! (-> pad old-rightx 1) (-> pad old-rightx 0))
  (set! (-> pad old-rightx 0) (-> pad rightx))
  (set! (-> pad old-righty 1) (-> pad old-righty 0))
  (set! (-> pad old-righty 0) (-> pad righty))
  
  (set! (-> pad button0-abs 2) (-> pad button0-abs 1))
  (set! (-> pad button0-abs 1) (-> pad button0-abs 0))
  (set! (-> pad button0-rel 2) (-> pad button0-rel 1))
  (set! (-> pad button0-rel 1) (-> pad button0-rel 0))

  ;; Shift *cpad-history-list* for recently-pressed? macro support
  (let ((history (-> *cpad-history-list* cpads (-> pad number))))
    (dotimes (i 14)
      (set! (-> history button0-abs (- 14 i)) (-> history button0-abs (- 13 i)))
      (set! (-> history button0-rel (- 14 i)) (-> history button0-rel (- 13 i)))
      )
    )

  ;; 2. Set new raw values
  (set! (-> pad valid) (the-as uint 0))
  (set! (-> pad status) (the-as uint #x73)) ;; DualShock 2 ID
  (set! (-> pad button0) buttons)
  (set! (-> pad leftx) lx)
  (set! (-> pad lefty) ly)
  (set! (-> pad rightx) rx)
  (set! (-> pad righty) ry)

  ;; Set analog button pressure from digital bitmask (Required for vehicles)
  (if (logtest? (the-as pad-buttons buttons) (pad-buttons x))
      (set! (-> pad abutton (abutton-idx x)) (the uint8 255))
      (set! (-> pad abutton (abutton-idx x)) (the uint8 0)))
  (if (logtest? (the-as pad-buttons buttons) (pad-buttons square))
      (set! (-> pad abutton (abutton-idx square)) (the uint8 255))
      (set! (-> pad abutton (abutton-idx square)) (the uint8 0)))
  (if (logtest? (the-as pad-buttons buttons) (pad-buttons triangle))
      (set! (-> pad abutton (abutton-idx triangle)) (the uint8 255))
      (set! (-> pad abutton (abutton-idx triangle)) (the uint8 0)))
  (if (logtest? (the-as pad-buttons buttons) (pad-buttons circle))
      (set! (-> pad abutton (abutton-idx circle)) (the uint8 255))
      (set! (-> pad abutton (abutton-idx circle)) (the uint8 0)))
  (if (logtest? (the-as pad-buttons buttons) (pad-buttons l1))
      (set! (-> pad abutton (abutton-idx l1)) (the uint8 255))
      (set! (-> pad abutton (abutton-idx l1)) (the uint8 0)))
  (if (logtest? (the-as pad-buttons buttons) (pad-buttons r1))
      (set! (-> pad abutton (abutton-idx r1)) (the uint8 255))
      (set! (-> pad abutton (abutton-idx r1)) (the uint8 0)))
  (if (logtest? (the-as pad-buttons buttons) (pad-buttons l2))
      (set! (-> pad abutton (abutton-idx l2)) (the uint8 255))
      (set! (-> pad abutton (abutton-idx l2)) (the uint8 0)))
  (if (logtest? (the-as pad-buttons buttons) (pad-buttons r2))
      (set! (-> pad abutton (abutton-idx r2)) (the uint8 255))
      (set! (-> pad abutton (abutton-idx r2)) (the uint8 0)))

  ;; 3. Update abs and rel buttons (Expansion of raw buttons to full enum)
  (let ((buttons-pushed (the-as pad-buttons buttons)))
     ;; Stick to D-Pad mapping (Matches service-cpads in pad.gc)
     (if (< lx (the-as uint 30)) (set! buttons-pushed (logior (pad-buttons l-analog-left) buttons-pushed)))
     (if (> lx (the-as uint 225)) (set! buttons-pushed (logior (pad-buttons l-analog-right) buttons-pushed)))
     (if (< ly (the-as uint 30)) (set! buttons-pushed (logior (pad-buttons l-analog-up) buttons-pushed)))
     (if (> ly (the-as uint 225)) (set! buttons-pushed (logior (pad-buttons l-analog-down) buttons-pushed)))
     
     ;; Right analog mapping
     (if (< rx (the-as uint 30)) (set! buttons-pushed (logior (pad-buttons r-analog-left) buttons-pushed)))
     (if (> rx (the-as uint 225)) (set! buttons-pushed (logior (pad-buttons r-analog-right) buttons-pushed)))
     (if (< ry (the-as uint 30)) (set! buttons-pushed (logior (pad-buttons r-analog-up) buttons-pushed)))
     (if (> ry (the-as uint 225)) (set! buttons-pushed (logior (pad-buttons r-analog-down) buttons-pushed)))

     (set! (-> pad button0-abs 0) buttons-pushed)
     )
  (set! (-> pad button0-rel 0) (logclear (-> pad button0-abs 0) (-> pad button0-abs 1)))

  ;; Update history index 0
  (let ((history (-> *cpad-history-list* cpads (-> pad number))))
    (set! (-> history button0-abs 0) (-> pad button0-abs 0))
    (set! (-> history button0-rel 0) (-> pad button0-rel 0))
    )

  ;; 4. Update stick dir and speed for physics/state machine checks
  (let ((f30-0 (* 0.0078125 (the float (+ (the int lx) -128))))
        (f28-0 (* 0.0078125 (the float (- 127 (the int ly))))))
    (set! (-> pad stick0-dir) (atan (- f30-0) f28-0))
    (set! (-> pad stick0-speed) (fmin 1.0 (sqrtf (+ (* f30-0 f30-0) (* f28-0 f28-0)))))
    )
  (if (< (-> pad stick0-speed) 0.3) ;; Standard Stick Deadzone
      (set! (-> pad stick0-speed) 0.0)
      )
  (none)
  )

(defun mp-puppet-note-remote-packet! ((info remote-player-info))
  "Track the last fresh remote player packet so input cannot replay forever."
  (let ((packet-id (-> info packet-id)))
    (when (!= packet-id *mp-puppet-last-packet-id*)
      (set! *mp-puppet-last-packet-id* packet-id)
      (set! *mp-puppet-last-fresh-input-time* (current-time))
      )
  )
  (none)
  )

(defun mp-puppet-apply-weapon-state! ((proc target) (ghost mp-target-ghost-record))
  "Bring the puppet's gun state in line with the remote player's equipped weapon."
  (when (and proc
             (nonzero? proc)
             (-> proc control)
             (-> ghost active?))
    (let ((weapon (the-as uint (-> ghost equipped-weapon))))
      (if (zero? weapon)
          (when (using-gun? proc)
            (send-event proc 'mp-put-gun-away)
            )
          (let ((gun-type (mp-equipped-weapon->pickup-type weapon)))
            (if (not (using-gun? proc))
                (send-event proc 'change-mode 'gun #f gun-type)
                (when (!= (-> proc gun gun-type) gun-type)
                  (send-event proc 'gun-type gun-type)
                  )
                )
            )
          )
      )
    )
  (none)
  )

(defun mp-puppet-flush-pending-gun-shot! ((proc target) (ghost mp-target-ghost-record))
  "Replay a queued remote gun shot once the puppet has finished equipping."
  (when (and *mp-puppet-pending-gun-shot?*
             proc
             (nonzero? proc)
             (-> proc control)
             (-> ghost active?))
    (mp-puppet-apply-weapon-state! proc ghost)
    (let ((weapon (mp-equipped-weapon->pickup-type *mp-puppet-pending-gun-shot-weapon*)))
      (when (and (using-gun? proc)
                 (= (-> proc gun gun-type) weapon))
        (set! *mp-processing-remote-event* #t)
        (send-event proc 'gun weapon)
        (set! *mp-processing-remote-event* #f)
        (set! *mp-puppet-pending-gun-shot?* #f)
        (set! *mp-puppet-pending-gun-shot-weapon* (the uint 0))
        (set! *mp-puppet-pending-gun-shot-seq* (the uint 0))
        (set! *mp-puppet-pending-gun-shot-cam-angle-y* 0.0)
        )
      )
    )
  (none)
  )

(defun mp-puppet-receive-gun-shot! ((evt mp-player-gun-shot-event))
  "Store a remote gun shot and try to replay it immediately."
  (when (> (-> evt shot-seq) *mp-last-remote-gun-shot-seq*)
    (set! *mp-last-remote-gun-shot-seq* (-> evt shot-seq))
    (set! *mp-puppet-pending-gun-shot?* #t)
    (set! *mp-puppet-pending-gun-shot-weapon* (the-as uint (-> evt weapon-type)))
    (set! *mp-puppet-pending-gun-shot-seq* (-> evt shot-seq))
    (set! *mp-puppet-pending-gun-shot-cam-angle-y* (-> evt cam-angle-y))

    (when (and *remote-info* (nonzero? (the-as uint *remote-info*)))
      (set! (-> *remote-info* equipped-weapon) (the-as uint8 (-> evt weapon-type)))
      (set! (-> *remote-info* cam-angle-y) (-> evt cam-angle-y))
      )
    (when (and (nonzero? (the-as uint *mp-puppet-ghost*))
               (-> *mp-puppet-ghost* active?))
      (set! (-> *mp-puppet-ghost* equipped-weapon) (the-as uint8 (-> evt weapon-type)))
      (set! (-> *mp-puppet-ghost* cam-angle-y) (-> evt cam-angle-y))
      )

    (let ((proc (mp-puppet-get-proc)))
      (when proc
        (mp-puppet-apply-weapon-state! proc *mp-puppet-ghost*)
        (mp-puppet-flush-pending-gun-shot! proc *mp-puppet-ghost*)
        )
      )
    )
  (none)
  )

(defun mp-puppet-remote-input-stale? ()
  "Has remote input gone stale long enough that replaying it is unsafe?"
  (or (zero? *mp-puppet-last-fresh-input-time*)
      (> (- (current-time) *mp-puppet-last-fresh-input-time*) *mp-puppet-input-stale-time*)
      )
  )

(defun mp-puppet-neutralize-pad! ((pad cpad-info))
  "Clear remote movement intent while preserving normal pad history bookkeeping."
  (mp-puppet-update-pad pad (the-as uint16 0) (the uint8 128) (the uint8 128) (the uint8 128) (the uint8 128))
  )

(defun mp-puppet-apply-input! ((proc target) (ghost mp-target-ghost-record))
  "Inject fresh remote input, or neutral input if packets have stopped arriving."
  (when (-> proc control cpad)
    (let ((buttons (the-as uint16 (-> ghost buttons))))
      (when (nonzero? (the-as uint (-> ghost equipped-weapon)))
        (set! buttons (logclear buttons (pad-buttons r1)))
        )
      (if (mp-puppet-remote-input-stale?)
          (mp-puppet-neutralize-pad! (-> proc control cpad))
          (mp-puppet-update-pad (-> proc control cpad)
                                buttons
                                (-> ghost leftx)
                                (-> ghost lefty)
                                (-> ghost rightx)
                                (-> ghost righty))
          )
      )
    )
  (none)
  )

(defun mp-target-state-attacking? ((state symbol))
  "Check if a target state is an attacking state where rotation tracking should be disabled."
  (case state
    (('target-attack
      'target-running-attack
      'target-attack-air
      'target-attack-uppercut
      'target-attack-uppercut-jump
      'target-darkjak-running-attack
      'target-indax-attack
      'target-indax-attack-air
      'target-indax-running-attack
      'target-indax-attack-uppercut
      'target-indax-attack-uppercut-jump
      )
     #t
     )
    (else #f)
    )
  )

(defun mp-puppet-apply-transform-correction! ((proc target) (ghost mp-target-ghost-record) (cur-state symbol))
  "Correct puppet drift without pulling vertical position through local collision."
  (when (not (focus-test? proc pilot tube flut mech pole))
    (let ((dist (vector-vector-distance (-> proc control trans) (-> ghost trans))))
      (cond
        ((> dist (meters 15.0))
         (vector-copy! (-> proc control trans) (-> ghost trans))
         (vector-copy! (-> proc control transv) (-> ghost velocity))
         )
        (else
         (let ((cur-pos (-> proc control trans))
               (ghost-pos (-> ghost trans))
               (xz-factor 0.2)
               (up-factor 0.15)
               (down-factor 0.05))
           (when (not (focus-test? proc grabbed))
             (set! (-> cur-pos x) (+ (-> cur-pos x) (* (- (-> ghost-pos x) (-> cur-pos x)) xz-factor)))
             (set! (-> cur-pos z) (+ (-> cur-pos z) (* (- (-> ghost-pos z) (-> cur-pos z)) xz-factor)))
             (if (> (-> ghost-pos y) (-> cur-pos y))
                 (set! (-> cur-pos y) (+ (-> cur-pos y) (* (- (-> ghost-pos y) (-> cur-pos y)) up-factor)))
                 (when (not (or (= cur-state 'target-falling)
                                (= cur-state 'target-indax-falling)
                                (= cur-state 'target-board-falling)
                                (= cur-state 'target-mech-falling)
                                (= cur-state 'target-carry-falling)))
                   (set! (-> cur-pos y) (+ (-> cur-pos y) (* (- (-> ghost-pos y) (-> cur-pos y)) down-factor)))
                   )
                 )
             )
           )
         )
        )
      )

    (when (not (mp-puppet-remote-input-stale?))
      (let ((cur-vel (-> proc control transv))
            (ghost-vel (-> ghost velocity))
            (vel-factor 0.35))
        (set! (-> cur-vel x) (+ (-> cur-vel x) (* (- (-> ghost-vel x) (-> cur-vel x)) vel-factor)))
        (set! (-> cur-vel y) (+ (-> cur-vel y) (* (- (-> ghost-vel y) (-> cur-vel y)) vel-factor)))
        (set! (-> cur-vel z) (+ (-> cur-vel z) (* (- (-> ghost-vel z) (-> cur-vel z)) vel-factor)))
        )
      )

    (when (not (mp-target-state-attacking? cur-state))
      (let ((slerp-factor 0.25))
        (quaternion-slerp! (-> proc control quat) (-> proc control quat) (-> ghost quat) slerp-factor)
        (quaternion-slerp! (-> proc control quat-for-control) (-> proc control quat-for-control) (-> ghost quat) slerp-factor)
        (quaternion-slerp! (-> proc control dir-targ) (-> proc control dir-targ) (-> ghost quat) slerp-factor)
        )
      )
    )
  (none)
  )

(defun mp-target-board-state? ((state symbol))
  "Check if a target state is any jetboard state."
  (case state
    (('target-board-start
      'target-board-stance
      'target-board-walk
      'target-board-duck-stance
      'target-board-jump
      'target-board-falling
      'target-board-jump-kick
      'target-board-halfpipe
      'target-board-get-on
      'target-board-get-off
      'target-board-hit
      )
     #t
     )
    (else #f)
    )
  )

(defun mp-puppet-in-board-state? ((proc target) (cur-state symbol))
  "Check if the local puppet already has board focus or is transitioning through board setup."
  (or (focus-test? proc board)
      (mp-target-board-state? cur-state)
      )
  )

(defun mp-target-pole-state? ((state symbol))
  "Check if a target state is any swingpole state."
  (case state
    (('target-pole-cycle
      'target-pole-flip-up
      'target-pole-flip-up-jump
      'target-pole-flip-forward
      'target-pole-flip-forward-jump
      'target-indax-pole-cycle
      'target-indax-pole-flip-up
      'target-indax-pole-flip-up-jump
      'target-indax-pole-flip-forward
      'target-indax-pole-flip-forward-jump
      )
     #t
     )
    (else #f)
    )
  )

(defun mp-puppet-in-pole-state? ((proc target) (cur-state symbol))
  "Check if the local puppet is attached to or transitioning through a swingpole."
  (or (focus-test? proc pole)
      (mp-target-pole-state? cur-state)
      )
  )

(defun mp-puppet-pilot-entry-mode ()
  (if (mp-is-jak?)
      'pilot-daxter
      'pilot
      )
  )

(defun mp-puppet-synced-to-vehicle-seat? ((proc target) (v-proc vehicle) (seat-index int))
  (and proc
       (nonzero? proc)
       v-proc
       (nonzero? v-proc)
       (focus-test? proc pilot)
       (nonzero? (-> proc pilot))
       (nonzero? (-> proc pilot vehicle))
       (= (handle->process-safe (-> proc pilot vehicle)) v-proc)
       (= (-> proc pilot seat-index) seat-index)
       )
  )

(deftype mp-base-turret-dummy (process-focusable)
  ((hud                    handle)
   (condition              int32)
   (shadow-backup          symbol)
   (rider                  handle)
   (actor-group            (pointer actor-group))
   (actor-group-count      int32)
   (alt-actor              symbol)
   (smush-control          smush-control        :inline)
   (sound-id               sound-id             3)
   (sound-playing          symbol               3)
   (cam-string-vector      vector               :inline)
   (path-event             structure)
   (path-u                 float)
   (path-u-prev            float)
   (path-mode              uint16)
   (path-speed             float)
   (path-speed-mult        float)
   (path-speed-mult-final  float)
   (path-old-pos           vector               :inline)
   (path-direction         symbol)
   (pause-proc             (function process symbol))
   (gun-recoil-jmod        joint-mod            4)
   (gun-index              int32)
   (shot-timeout           time-frame)
   (fire-time              time-frame)
   (fire-time-interval     time-frame)
   (enable-controls        symbol)
   (available-for-pickup   symbol)
   (roty                   degrees)
   (rotyv                  degrees)
   (rotyvv                 degrees)
   (roty-min               degrees)
   (roty-max               degrees)
   (rotx                   degrees)
   (rotxv                  degrees)
   (rotxvv                 degrees)
   (rotx-min               degrees)
   (rotx-max               degrees)
   )
  )

(deftype mp-turret-info-dummy (basic)
  ((process   (pointer process))
   (handle    handle)
   (turret    pointer)
   (grabbed?  symbol)
   (quat      quaternion  :inline)
   (trans     vector      :inline)
   )
  )

(defun mp-puppet-synced-to-turret? ((proc target) (t-proc mp-base-turret-dummy))
  (and proc
       (nonzero? proc)
       t-proc
       (nonzero? t-proc)
       (nonzero? (-> proc turret))
       (= (handle->process-safe (-> (the-as mp-turret-info-dummy (-> proc turret)) handle)) t-proc)
       (nonzero? (-> proc state))
       (or (= (-> proc state name) 'target-turret-stance)
           (= (-> proc state name) 'target-turret-get-on))
       )
  )

(defun mp-puppet-apply-turret-aim! ((turret-proc mp-base-turret-dummy) (info remote-player-info))
  (when (and turret-proc
             (nonzero? turret-proc)
             info
             (nonzero? info)
             (nonzero? (-> info turret-active)))
    (set! (-> turret-proc enable-controls) #f)
    (set! (-> turret-proc roty) (-> info turret-roty))
    (set! (-> turret-proc rotyv) 0.0)
    (set! (-> turret-proc rotyvv) 0.0)
    (set! (-> turret-proc rotx) (-> info turret-rotx))
    (set! (-> turret-proc rotxv) 0.0)
    (set! (-> turret-proc rotxvv) 0.0)
    )
  (none)
  )

(defun mp-puppet-start-vehicle-entry! ((proc target) (v-proc vehicle) (seat-index int))
  "Start native pilot get-on for the puppet without pre-snapping into the seat."
  (when (and proc
             (nonzero? proc)
             (-> proc control)
             v-proc
             (nonzero? v-proc)
             (>= seat-index 0)
             (< seat-index 4))
    (mp-vehicle-clear-seat-occupant! v-proc seat-index proc)
    (remove-rider v-proc proc)
    (send-event proc 'change-mode (mp-puppet-pilot-entry-mode) v-proc seat-index #f)
    )
  (none)
  )

(define *mp-jak-death-vo* (new 'static 'boxed-array :type string "jak065" "jak034" "jak076" "jak077" "jak042" "jak078"))
(define *mp-daxter-death-vo* (new 'static 'boxed-array :type string "ds199" "ds285" "ds490" "ds489" "dsek008" "dsek007"))

(defun mp-play-random-vo ((speaker process) (channel gui-channel) (vo-keys (array string)))
  "Play a random voice line from an array of vo-keys using the specified speaker and channel."
  (when (and speaker (nonzero? speaker) vo-keys (nonzero? vo-keys) (> (-> vo-keys length) 0))
    (let* ((idx (rand-vu-int-range 0 (+ (-> vo-keys length) -1)))
           (vo-key (-> vo-keys idx))
           )
      (when (and *gui-control* (nonzero? *gui-control*))
        (add-process *gui-control* speaker channel (gui-action play) vo-key -99.0 0)
        )
      )
    )
  (none)
  )

(defun mp-play-remote-death-vo ()
  "Play a funny voice line when the remote player dies."
  (when (and *target*
             (nonzero? *target*)
             (-> *target* state)
             (nonzero? (-> *target* state))
             (not (mp-target-death-state? (-> *target* state name))))
    (if (mp-is-jak?)
        (mp-play-random-vo *target* (gui-channel jak) *mp-jak-death-vo*)
        (mp-play-random-vo *target* (gui-channel daxter) *mp-daxter-death-vo*)
        )
    )
  (none)
  )

(defun mp-play-local-death-vo ()
  "Play a funny voice line from the remote player when the local player dies."
  (when (and *mp-puppet*
             (nonzero? *mp-puppet*)
             (not *remote-player-is-dead*)
             (not *remote-player-is-dying*))
    (if (mp-is-jak?)
        (mp-play-random-vo *mp-puppet* (gui-channel daxter) *mp-daxter-death-vo*)
        (mp-play-random-vo *mp-puppet* (gui-channel jak) *mp-jak-death-vo*)
        )
    )
  (none)
  )

(defun mp-puppet-apply-ghost-correction! ((proc target))
  "Smoothly nudge the puppet target's root towards the ghost position and inject inputs."
  (let ((ghost *mp-puppet-ghost*))
    (when (and proc (-> ghost active?) (-> proc control))
      ;; CRITICAL: Ensure the process is never culled by distance/kernel optimizations
      (logclear! (-> proc mask) (process-mask pause sleep actor-pause))

      (let ((cur-state (if (-> proc state) (-> proc state name) #f)))
        ;; 1. Position/Rotation Sync (P-Controller)
        (mp-puppet-apply-transform-correction! proc ghost cur-state)

        ;; 3. State Bumping (Reconciliation Fallback)
        (let ((ghost-state (mp-target-get-state-from-id (-> ghost state-id))))
          (when (and ghost-state (!= cur-state ghost-state))
            (+! *mp-puppet-state-mismatch-count* 1)
            (cond
              ((and (mp-target-death-state? ghost-state)
                    (not (mp-target-death-state? cur-state)))
               (format 0 "[MP-Puppet] Authoritative Death! Bumping ~A -> ~A~%" cur-state ghost-state)
               (set! *remote-player-is-dying* #t)
               (send-event proc 'mp-die)
               (mp-play-remote-death-vo)
               (set! *mp-puppet-state-mismatch-count* 0)
               )
              ((and (mp-target-death-state? ghost-state)
                    (mp-target-death-state? cur-state))
               (set! *mp-puppet-state-mismatch-count* 0)
               )
              ((or (= ghost-state 'target-hit) (= ghost-state 'target-indax-hit))
               (send-event proc 'mp-hit)
               (set! *mp-puppet-state-mismatch-count* 0)
               )
              ((= ghost-state 'target-ride-along)
               (format 0 "[MP-Puppet] Authoritative Ride Along! Bumping ~A -> ~A~%" cur-state ghost-state)
               ;; Safety: Ensure puppet has a valid pad before entering a state that checks inputs
               (when (not (-> proc control cpad))
                 (set! (-> proc control cpad) (-> *cpad-list* cpads 1))
                 )
               (go-process proc target-ride-along)
               (set! *mp-puppet-state-mismatch-count* 0)
               )
              ((and (mp-target-board-state? ghost-state)
                    (not (mp-puppet-in-board-state? proc cur-state)))
               (format 0 "[MP-Puppet] Authoritative Board! Bumping ~A -> ~A~%" cur-state ghost-state)
               ;; Use the native mode change so target-board-init spawns and opens the board model.
               (send-event proc 'change-mode 'board #f)
               (set! *mp-puppet-state-mismatch-count* 0)
               )
              ((and (not (mp-target-board-state? ghost-state))
                    (mp-puppet-in-board-state? proc cur-state))
               (when (>= *mp-puppet-state-mismatch-count* 10)
                 (format 0 "[MP-Puppet] Authoritative Non-Board! Bumping ~A -> ~A~%" cur-state ghost-state)
                 (send-event proc 'change-mode 'normal)
                 (set! *mp-puppet-state-mismatch-count* 0)
                 )
               )
              ((and (not (mp-target-pole-state? ghost-state))
                    (mp-puppet-in-pole-state? proc cur-state))
               (when (>= *mp-puppet-state-mismatch-count* 10)
                 (format 0 "[MP-Puppet] Authoritative Non-Pole! Bumping ~A -> ~A~%" cur-state ghost-state)
                 (send-event proc 'end-mode 'pole)
                 (set! *mp-puppet-state-mismatch-count* 0)
                 )
               )
              ((= cur-state 'process-drawable-art-error)
                (when (>= *mp-puppet-state-mismatch-count* 10)
                  (format 0 "[MP-Puppet] Stuck in drawable art error! Forcing exit...~%")
                  (deactivate proc)
                  (set! *mp-puppet* (the-as target #f))
                  (set! *mp-puppet-state-mismatch-count* 0)
                  )
              )
              ((= cur-state 'target-ride-along)
               ;; Puppet thinks it's riding, but ghost is NOT.
               (when (!= ghost-state 'target-ride-along)
                 (when (>= *mp-puppet-state-mismatch-count* 10)
                   (format 0 "[MP-Puppet] Stuck in ride-along! Forcing exit to ~A~%" ghost-state)
                   ;; Transition directly to the authoritative state via event; :exit handles cleanup
                   (set! *local-riding?* #f)
                   (send-event proc 'change-mode 'normal #f)
                   (set! *mp-puppet-state-mismatch-count* 0)
                   )
                 )
               )
              ((or (= cur-state 'target-edge-grab)
                   (= cur-state 'target-indax-edge-grab)
                   (= cur-state 'target-pilot-edge-grab)
                   (= cur-state 'target-indax-pilot-edge-grab)
                   )
               ;; Puppet is hanging, but ghost is NOT.
               (when (not (or (= ghost-state 'target-edge-grab)
                              (= ghost-state 'target-indax-edge-grab)
                              (= ghost-state 'target-pilot-edge-grab)
                              (= ghost-state 'target-indax-pilot-edge-grab)
                              )
                          )
                 (when (>= *mp-puppet-state-mismatch-count* 10)
                   (format 0 "[MP-Puppet] Stuck in hang! Forcing exit via 'end-mode...~%")
                   (send-event proc 'end-mode 'edge-grab)
                   (set! *mp-puppet-state-mismatch-count* 0)
                   )
                 )
               )
              )
            )
          (when (= cur-state ghost-state)
            (set! *mp-puppet-state-mismatch-count* 0)
            )
          )

        ;; --- 3.5. Occupancy Sync (Direct Attachment) ---
        (let ((info *remote-info*)
              (ghost-state (mp-target-get-state-from-id (-> ghost state-id))))
          (let ((riding-veh-id (-> info riding-veh-id))
                (riding-seat-index (-> info riding-seat-index)))
            (cond
              ((and (mp-target-death-state? ghost-state)
                    (focus-test? proc pilot)
                    (nonzero? (-> proc pilot))
                    (nonzero? (-> proc pilot vehicle)))
               ;; Death owns the puppet now; do not keep it welded to a stale vehicle seat.
               (let ((v-proc (the-as vehicle (handle->process-safe (-> proc pilot vehicle))))
                     (seat-index (-> proc pilot seat-index)))
                  (when (and v-proc (nonzero? v-proc))
                    (remove-rider v-proc proc)
                    (when (and (>= seat-index 0) (< seat-index 4))
                      (set! (-> v-proc rider-array seat-index) (the-as handle #f))
                      )
                    )
                  (set! (-> proc pilot vehicle) (the-as handle #f))
                  (set! (-> proc pilot seat-index) 0)
                  (logclear! (-> proc focus-status) (focus-status pilot pilot-riding))
                  )
                )
              ((and (nonzero? riding-veh-id)
                    (or (= ghost-state 'target-turret-stance)
                        (= ghost-state 'target-turret-get-on)))
               ;; Remote player is in a turret.
               (let* ((turret-ent (entity-by-aid riding-veh-id))
                      (turret-proc (the-as mp-base-turret-dummy (if (and turret-ent (nonzero? turret-ent)) (-> turret-ent extra process) #f))))
                 (when (and turret-proc (nonzero? turret-proc))
                   (mp-puppet-apply-turret-aim! turret-proc info)
                   (when (not (mp-puppet-synced-to-turret? proc turret-proc))
                     (format 0 "[MP-Puppet] Synced to turret (AID ~D)! Starting turret entry.~%" riding-veh-id)

                     ;; Clean up old vehicle occupancy if any
                     (when (and (focus-test? proc pilot)
                                (nonzero? (-> proc pilot))
                                (nonzero? (-> proc pilot vehicle)))
                       (let ((v-proc (the-as vehicle (handle->process-safe (-> proc pilot vehicle))))
                             (seat-index (-> proc pilot seat-index)))
                         (when (and v-proc (nonzero? v-proc))
                           (remove-rider v-proc proc)
                           (if (and (>= seat-index 0) (< seat-index 4))
                               (set! (-> v-proc rider-array seat-index) (the-as handle #f))
                               )
                           )
                         )
                       )

                     ;; Attach the puppet as the rider of this turret!
                     (set! (-> turret-proc rider) (process->handle proc))
                     (set! (-> turret-proc available-for-pickup) #f)

                     ;; Send the puppet to target-turret-get-on
                     (send-event proc 'change-state target-turret-get-on (process->handle turret-proc))
                     )
                   )
                 )
               )
              ((nonzero? riding-veh-id)
               ;; Remote player is in a vehicle.
               (let ((v-proc (mp-vehicle-find-by-net-id riding-veh-id)))
                 (when (and v-proc (nonzero? v-proc))
                   (let ((seat-index (the int riding-seat-index)))
                     (when (not (mp-puppet-synced-to-vehicle-seat? proc v-proc seat-index))
                       ;; Native pilot get-on attaches the rider at the animation-ready frame.
                       (mp-puppet-start-vehicle-entry! proc v-proc seat-index)
                       )
                     )
                   )
                 )
               )
              ((and (or (= cur-state 'target-turret-stance)
                        (= cur-state 'target-turret-get-on))
                    (not (or (= ghost-state 'target-turret-stance)
                             (= ghost-state 'target-turret-get-on))))
               ;; Remote player exited turret, but puppet is still in it. Force exit.
               (format 0 "[MP-Puppet] Puppet is in turret but ghost is not! Forcing exit.~%")
               (send-event proc 'change-state (if (mp-is-jak?) target-indax-start target-stance) (the handle #f))
               (when (and (nonzero? (-> proc turret)) (nonzero? (-> (the-as mp-turret-info-dummy (-> proc turret)) handle)))
                 (let ((turret-proc (the-as mp-base-turret-dummy (handle->process (-> (the-as mp-turret-info-dummy (-> proc turret)) handle)))))
                   (when (and turret-proc (nonzero? turret-proc))
                     (set! (-> turret-proc rider) (the-as handle #f))
                     (set! (-> turret-proc available-for-pickup) #t)
                     (set! (-> turret-proc enable-controls) #t)
                     (send-event turret-proc 'exit)
                     )
                   )
                 )
               )
              ((and (focus-test? proc pilot) 
                    (nonzero? (-> proc pilot))
                    (nonzero? (-> proc pilot vehicle)))
               ;; Remote player is NOT in a vehicle, but puppet still is. Detach.
               (send-event proc 'change-mode (if (mp-is-jak?) 'indax 'normal) #f)
               (let ((v-proc (the-as vehicle (handle->process (-> proc pilot vehicle)))))
                 (if (and v-proc (nonzero? v-proc))
                     (set! (-> v-proc rider-array (-> proc pilot seat-index)) (the-as handle #f))
                     )
                 )
               )
              )
            )
          )

        ;; 4. Weapon/Input Sync (Authoritative gun state first, then raw input)
        (mp-puppet-apply-weapon-state! proc ghost)
        (mp-puppet-apply-input! proc ghost)
        (mp-puppet-flush-pending-gun-shot! proc ghost)
      )

      ;; 5. Camera Orientation Sync
      ;; Construct a camera-relative input matrix from the remote player's camera angle.
      (matrix-rotate-y! (-> proc control cam-R-w) (-> ghost cam-angle-y))
      ;; Prevent the target state machine from overwriting this with the local camera.
      (set! (-> proc control update-cam-R-w-start-time) (the-as int64 #x7fffffffffffffff))

      ;; 6. Permanent Jak Hiding (Daxter Puppets)
      (if (mp-is-jak?)
          (logior! (-> proc draw status) (draw-control-status no-draw-bounds2))
          )
      )
    )
  (none)
)

(defbehavior mp-puppet-init target ((arg0 continue-point))
  "Initialize a target process as a remote player puppet. Bypasses continue/title states."
  (init-target self arg0 'mp-puppet)
  (remove-setting! 'allow-pause)
  (remove-setting! 'allow-progress)

  ;; Add minimap icon
  (add-icon! *minimap* self (the-as uint (minimap-class remote-player)) (the-as int #f) (the-as vector #t) 0)

  ;; Directly go to the correct state based on role to avoid resets/overrides
  (if (mp-is-jak?)
      (go target-indax-start (the handle #f))
      (go target-stance)
      )
  (none)
  )

(defun mp-puppet-alive? ()
  "Returns true if the specified target is currently alive."
  (and *mp-puppet*
       (nonzero? *mp-puppet*)
       (not (focus-test? *mp-puppet* inactive))
       (-> *mp-puppet* state)
       (nonzero? (-> *mp-puppet* state))
       (not (= (-> *mp-puppet* state name) 'dead))
       )
  )

(defun mp-puppet-get-proc ()
  "Find the puppet target process if it exists."
  (if (mp-puppet-alive?)
      *mp-puppet*
      (the-as target #f)
      )
  )

(defun mp-puppet-deactivate! ()
  "Deactivate and clear the remote puppet singleton if the process is still valid."
  (let ((puppet (mp-puppet-get-proc)))
    (when (and puppet (nonzero? puppet))
      (deactivate puppet)
      )
    )
  (set! *mp-puppet* (the-as target #f))
  (set! *mp-puppet-pending-gun-shot?* #f)
  (set! *mp-puppet-pending-gun-shot-weapon* (the uint 0))
  (set! *mp-puppet-pending-gun-shot-seq* (the uint 0))
  (set! *mp-puppet-pending-gun-shot-cam-angle-y* 0.0)
  (none)
  )

(defun mp-puppet-spawn ((id uint))
  "Spawn a new puppet target using native engine initialization."
  (when (and (not (mp-puppet-alive?))
             *target*
             (-> *game-info* current-continue)
             ;; Safety: Don't spawn if we are in title or demo (Check next-state AND current state)
             (not (or (and (-> *target* next-state) (or (= (-> *target* next-state name) 'target-title)
                                                        (= (-> *target* next-state name) 'target-demo)))
                      (and (-> *target* state) (or (= (-> *target* state name) 'target-title)
                                                   (= (-> *target* state name) 'target-demo))))))
    (format 0 "[MP-Puppet] Spawning new target puppet with ID ~D...~%" id)
    (let ((p (process-spawn target :init mp-puppet-init (-> *game-info* current-continue) :from *target-dead-pool* :to *target-pool* :stack *kernel-dram-stack*)))
      (when p
        (set! *mp-puppet* (-> p 0))
        (set! (-> *mp-puppet* name) "mp-puppet")
        (set! *local-riding?* #f)
        (set! *mp-puppet-state-mismatch-count* 0)
        (set! *remote-player-is-dying* #f)
        (set! *remote-player-is-dead* #f)
        (set! *mp-local-player-is-respawning* #f)
        
        ;; Assign the second pad in the global list to the puppet
        ;; We use pad 1 (controller 2) as the dedicated puppet pad
        (set! (-> *mp-puppet* control cpad) (-> *cpad-list* cpads 1))
        (set! (-> *cpad-list* num-cpads) 1) ;; Stop the engine from clearing it with hardware polls
        
        ;; If we are the Host (Jak), the remote player is Daxter. 
        ;; Send native change-mode event to initialize Indax (Daxter) states and skeletons.
        (if (mp-is-jak?)
          (begin
            (send-event *mp-puppet* 'change-mode 'indax #f)
            (when *mp-puppet-is-recovering?*
              (set! *mp-puppet-is-recovering?* #f)
              (go-process *mp-puppet* target-indax-spawn-reset)
            )
          )
        )
      )
    )
  )
  *mp-puppet*
)
