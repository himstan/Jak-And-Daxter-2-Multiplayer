  (none)
  )

(defun mp-vehicle-method-137-hijack ((this vehicle) (params traffic-object-spawn-params))
  "Keep ambient rider spawning from preserving stale local/puppet driver handles."
  (mp-vehicle-clear-stale-player-driver! this)
  (if (and (type? this vehicle-guard)
           *old-vehicle-guard-method-137*)
      (*old-vehicle-guard-method-137* (the-as vehicle-guard this) params)
      (if *old-vehicle-method-137*
          (*old-vehicle-method-137* this params)
          )
      )
  (mp-vehicle-clear-stale-player-driver! this)
  (none)
  )

(defun mp-vehicle-method-52-hijack ((this vehicle))
