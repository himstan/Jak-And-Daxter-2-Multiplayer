;;-*-Lisp-*-
(in-package goal)

(define-perm *mp-stadium-board1-local-tutorial-done?* symbol #f)
(define-perm *mp-stadium-board1-local-tutorial-announced?* symbol #f)
(define-perm *mp-stadium-board1-remote-tutorial-done?* symbol #f)
(define-perm *mp-stadium-board1-active?* symbol #f)
(define-perm *mp-stadium-board1-local-score* int 0)
(define-perm *mp-stadium-board1-remote-score* int 0)
(define-perm *mp-stadium-board1-last-score-sent* int -1)
(define-perm *mp-stadium-board1-last-score-send-time* time-frame 0)
(define-perm *mp-stadium-board1-remote-finished?* symbol #f)
(define-perm *mp-stadium-board1-local-finished?* symbol #f)
(define-perm *mp-stadium-board1-result-until* time-frame 0)
(define-perm *mp-stadium-board1-result-kind* int 0)
(define-perm *mp-stadium-board1-ramp-force-opened?* symbol #f)
(define-perm *mp-stadium-board1-ramp-force-closed?* symbol #f)
(define-perm *mp-stadium-board1-local-judge-started?* symbol #f)
(define-perm *mp-stadium-board1-pending-remote-start?* symbol #f)

(deftype mp-stadium-board1-event (mp-event)
  ((mission-evt     uint32     :overlay-at (-> data 0))
   (score           int32      :overlay-at (-> data 4))
   (unused          uint32     :overlay-at (-> data 8))
   )
  )

(deftype stadium-board1-hud-main-green-score (hud)
  ()
  )

(deftype stadium-board1-hud-dual-score (hud)
  ()
  )

(deftype stadium-board1-hud-side-green-score (hud)
  ()
  )

(deftype stadium-board1-hud-side-red-score (hud)
  ()
  )

(defun mp-stadium-board1-queue-event ((evt-id uint) (score int))
  (when (and *multi-sync-enabled?*
             (= (pc-multi-get-status) 6)
             (not *mp-processing-remote-event*))
    (let ((q-idx *mp-event-queue-write-ptr*))
      (let ((evt (the-as mp-stadium-board1-event (-> *mp-event-queue* q-idx))))
        (set! (-> evt etype) MP_EVENT_MISSION_EVENT)
        (dotimes (i 480)
          (set! (-> evt data i) (the-as uint8 0))
          )
        (set! (-> evt mission-evt) evt-id)
        (set! (-> evt score) score)
        (set! (-> evt unused) (the uint 0))
        )
      (set! *mp-event-queue-write-ptr* (logand (+ q-idx 1) 31))
      )
    )
  (none)
  )

(defun mp-stadium-board1-reset ()
  (set! *mp-stadium-board1-local-tutorial-done?* #f)
  (set! *mp-stadium-board1-local-tutorial-announced?* #f)
  (set! *mp-stadium-board1-remote-tutorial-done?* #f)
  (set! *mp-stadium-board1-active?* #f)
  (set! *mp-stadium-board1-local-score* 0)
  (set! *mp-stadium-board1-remote-score* 0)
  (set! *mp-stadium-board1-last-score-sent* -1)
  (set! *mp-stadium-board1-last-score-send-time* 0)
  (set! *mp-stadium-board1-remote-finished?* #f)
  (set! *mp-stadium-board1-local-finished?* #f)
  (set! *mp-stadium-board1-result-until* 0)
  (set! *mp-stadium-board1-result-kind* 0)
  (set! *mp-stadium-board1-ramp-force-opened?* #f)
  (set! *mp-stadium-board1-local-judge-started?* #f)
  (set! *mp-stadium-board1-pending-remote-start?* #f)
  (none)
  )

(defun mp-stadium-board1-reset-scores ()
  (set! *mp-stadium-board1-local-score* 0)
  (set! *mp-stadium-board1-remote-score* 0)
  (set! *mp-stadium-board1-last-score-sent* -1)
  (set! *mp-stadium-board1-last-score-send-time* 0)
  (set! *mp-stadium-board1-result-until* 0)
  (set! *mp-stadium-board1-result-kind* 0)
  (none)
  )

(defun mp-stadium-board1-mission-active? ()
  (and *multi-sync-enabled?*
       (= (pc-multi-get-status) 6)
       (not (task-node-closed? (game-task-node stadium-board1-resolution)))
       )
  )

(defun mp-stadium-board1-broadcast-tutorial-done! ()
  (when (and (mp-stadium-board1-mission-active?)
             *mp-stadium-board1-local-tutorial-done?*
             (not *mp-stadium-board1-local-tutorial-announced?*))
    (set! *mp-stadium-board1-local-tutorial-announced?* #t)
    (format 0 "[MP-StadiumBoard1] Local player completed the tutorial. Broadcasting to peer...~%")
    (mp-stadium-board1-queue-event MP_MISSION_EVT_STADIUM_BOARD1_TUTORIAL_DONE 0)
    )
  (none)
  )


(defun mp-stadium-board1-both-tutorials-done? ()
  (if *multi-sync-enabled?*
      (and *mp-stadium-board1-local-tutorial-done?*
           *mp-stadium-board1-remote-tutorial-done?*)
      (not (task-node-open? (game-task-node stadium-board1-training)))
      )
  )

(defun mp-stadium-board1-should-wait-for-peer? ()
  (and (mp-stadium-board1-mission-active?)
       *mp-stadium-board1-local-tutorial-done?*
       (not *mp-stadium-board1-remote-tutorial-done?*)
       )
  )

(defun mp-stadium-board1-mark-tutorial-done! ()
  (set! *mp-stadium-board1-local-tutorial-done?* #t)
  (format 0 "[MP-StadiumBoard1] Local player completed the tutorial.~%")
  (mp-stadium-board1-broadcast-tutorial-done!)
  (none)
  )

(defun mp-stadium-board1-mark-local-judge-started! ()
  (set! *mp-stadium-board1-local-judge-started?* #t)
  (none)
  )

(defun mp-stadium-board1-start-challenge! ((send-event? symbol))
  ;; log the bools below, and the send event flag
  (format 0 "[MP-StadiumBoard1] Starting challenge. Stadium mission active?: ~A, Stadium not active?: ~A, Send Event: ~A~%"
          (mp-stadium-board1-mission-active?) (not *mp-stadium-board1-active?*) send-event?)
  (when (and (mp-stadium-board1-mission-active?)
             (not *mp-stadium-board1-active?*))
      (set! *mp-stadium-board1-active?* #t)
      (set! *mp-stadium-board1-local-score* 0)
      (set! *mp-stadium-board1-remote-score* 0)
      (set! *mp-stadium-board1-last-score-sent* -1)
      (set! *mp-stadium-board1-last-score-send-time* 0)
      (set! *mp-stadium-board1-local-finished?* #f)
      (set! *mp-stadium-board1-remote-finished?* #f)
      (when send-event?
        (format 0 "[MP-StadiumBoard1] Starting challenge. Broadcasting to peer...~%")
        (mp-stadium-board1-queue-event MP_MISSION_EVT_STADIUM_BOARD1_CHALLENGE_START 0)
      )
    )
  (none)
  )

(defun mp-stadium-board1-local-judge-activated! ((send-event? symbol))
  (mp-stadium-board1-mark-local-judge-started!)
  (mp-stadium-board1-start-challenge! send-event?)
  (none)
  )

(defun mp-stadium-board1-try-remote-start-judge! ()
  (when *mp-stadium-board1-pending-remote-start?*
    (cond
      ((and *stadium-board1-judge* (nonzero? *stadium-board1-judge*) *target* (nonzero? *target*))
        (format 0 "[MP-StadiumBoard1] Delivering pending challenge start to judge ~A.~%" *stadium-board1-judge*)
        (set! *mp-stadium-board1-pending-remote-start?* #f)
        (send-event (handle->process (ppointer->handle *stadium-board1-judge*)) 'mp-start :from *target*)
        )
      ((and (not *stadium-board1-judge*))
        (format 0 "[MP-StadiumBoard1] Judge handle is stale; waiting for next judge spawn.~%")
        )
      (else
        (format 0 "[MP-StadiumBoard1] Remote challenge start pending; judge not ready.~%")
        )
      )
    )
  (none)
  )

(defun mp-stadium-board1-challenge-active? ()
  (and *mp-stadium-board1-active?*)
  )

(defun mp-stadium-board1-current-local-score ()
  (the int (-> *game-info* score))
  )

(defun mp-stadium-board1-effective-score ()
  (let ((local-score (if (and *game-info* (nonzero? *game-info*))
                         (the int (-> *game-info* score))
                         0
                         )))
    (if (and *multi-sync-enabled?* (> *mp-stadium-board1-remote-score* local-score))
        *mp-stadium-board1-remote-score*
        local-score
        )
    )
  )

(defun mp-stadium-board1-hud-local-score ()
  (mp-stadium-board1-current-local-score)
  )

(defun mp-stadium-board1-hud-remote-score ()
  *mp-stadium-board1-remote-score*
  )

(defun stadium-board1-hud-local-green? ()
  (and *multi-sync-enabled?* (mp-is-daxter?))
  )

(defun stadium-board1-hud-local-color ()
  (if (stadium-board1-hud-local-green?)
      (font-color green)
      (font-color red)
      )
  )

(defun stadium-board1-hud-remote-color ()
  (if (stadium-board1-hud-local-green?)
      (font-color red)
      (font-color green)
      )
  )

(defun mp-stadium-board1-broadcast-score! ((score int) (force? symbol))
  (let ((previous-score *mp-stadium-board1-last-score-sent*))
    (when (and *multi-sync-enabled?*
               (= (pc-multi-get-status) 6)
               *mp-stadium-board1-active?*
               (or force?
                   (!= score previous-score)))
      (format 0 "[MP-StadiumBoard1] Broadcasting score update. Score: ~D, Last Sent Score: ~D, Force: ~A~%"
              score previous-score force?)
      (set! *mp-stadium-board1-last-score-sent* score)
      (set! *mp-stadium-board1-last-score-send-time* (current-time))
    (mp-stadium-board1-queue-event MP_MISSION_EVT_STADIUM_BOARD1_SCORE_UPDATE score)
      )
    )
  (none)
  )

(defun mp-stadium-board1-finish-local-challenge! ((send-event? symbol))
  (let ((score (mp-stadium-board1-current-local-score)))
    (set! *mp-stadium-board1-local-score* score)
    (set! *mp-stadium-board1-local-finished?* #t)
    (set! *mp-stadium-board1-active?* #f)
    (mp-stadium-board1-broadcast-score! score #t)
    (when send-event?
      (mp-stadium-board1-queue-event MP_MISSION_EVT_STADIUM_BOARD1_CHALLENGE_END score)
    )
    )
  (none)
  )

(defun mp-stadium-board1-set-result! ()
  (let ((local-jak? (mp-is-jak?))
        (local-score *mp-stadium-board1-local-score*)
        (remote-score *mp-stadium-board1-remote-score*))
    (cond
      ((= local-score remote-score)
       (set! *mp-stadium-board1-result-kind* 3)
       )
      ((> local-score remote-score)
       (set! *mp-stadium-board1-result-kind* (if local-jak? 1 2))
       )
      (else
        (set! *mp-stadium-board1-result-kind* (if local-jak? 2 1))
        )
      )
    (set! *mp-stadium-board1-result-until* (+ (current-time) (seconds 10)))
    )
  (none)
  )

(defun mp-stadium-board1-post-challenge-finished! ((send-event? symbol))
  (when (not *mp-stadium-board1-local-finished?*)
    (mp-stadium-board1-finish-local-challenge! send-event?))
  (set! *mp-stadium-board1-active?* #f)
  (set! *mp-stadium-board1-local-judge-started?* #f)
  (mp-stadium-board1-set-result!)
  (none)
  )

(defun mp-stadium-board1-tick ()
  (when (mp-stadium-board1-mission-active?)
    (when *mp-stadium-board1-active?*
      (set! *mp-stadium-board1-local-score* (mp-stadium-board1-current-local-score))
      (when (mp-stadium-board1-challenge-active?)
        (mp-stadium-board1-broadcast-score! *mp-stadium-board1-local-score* #f)
        )
      )
    )
  (none)
  )

(defun mp-stadium-board1-receive-event ((evt mp-stadium-board1-event))
  (format 0 "[MP-StadiumBoard1] Received mission event ~D. Score: ~D~%" (-> evt mission-evt) (-> evt score))
  (case (-> evt mission-evt)
    ((MP_MISSION_EVT_STADIUM_BOARD1_TUTORIAL_DONE)
     (set! *mp-stadium-board1-remote-tutorial-done?* #t)
     )
    ((MP_MISSION_EVT_STADIUM_BOARD1_CHALLENGE_START)
     (set! *mp-stadium-board1-pending-remote-start?* #t)
     (mp-stadium-board1-try-remote-start-judge!)
     )
    ((MP_MISSION_EVT_STADIUM_BOARD1_SCORE_UPDATE)
     (set! *mp-stadium-board1-remote-score* (-> evt score))
     )
    ((MP_MISSION_EVT_STADIUM_BOARD1_CHALLENGE_END)
     (set! *mp-stadium-board1-remote-score* (-> evt score))
     (mp-stadium-board1-post-challenge-finished! #f)
     )
    ((MP_MISSION_EVT_STADIUM_BOARD1_BOARD_PICKED_UP)
     (let ((manager (process-by-type-exact 'hoverboard-training-manager *active-pool*)))
       (when (and manager (nonzero? manager))
         (send-event manager 'notify 'pickup)
         )
       )
     )
    )
  (none)
  )

(defun mp-stadium-board1-render-message ((text-msg text-id) (y int))
  (let ((message (lookup-text! *common-text* text-msg #f)))
    (when (and message (nonzero? message))
      (let ((ctx (new 'stack 'font-context *font-default-matrix* 32 y 0.0 (font-color default) (font-flags shadow kerning large))))
        (set-width! ctx 520)
        (set-height! ctx 80)
        (set-scale! ctx 0.75)
        (print-game-text message ctx #f 44 (bucket-id progress))
        )
      )
    )
  (none)
  )

(defun mp-stadium-board1-render-waiting-text ()
  (when (mp-stadium-board1-should-wait-for-peer?)
    (mp-stadium-board1-render-message (text-id stadium-waiting-for-other-player) 280)
    )
  (none)
  )

(defun mp-stadium-board1-render-result-text ()
  (when (and (nonzero? *mp-stadium-board1-result-until*)
             (< (current-time) *mp-stadium-board1-result-until*))
    (case *mp-stadium-board1-result-kind*
      ((1) (mp-stadium-board1-render-message (text-id stadium-jak-won) 240))
      ((2) (mp-stadium-board1-render-message (text-id stadium-daxter-won) 240))
      ((3) (mp-stadium-board1-render-message (text-id stadium-tie) 240))
      )
    )
  (none)
  )

(defmethod draw ((this stadium-board1-hud-main-green-score))
  (set-hud-piece-position!
    (the-as hud-sprite (-> this sprites))
    480
    140
    )
  (format (clear (-> this strings 0 text)) "~D" (-> this values 0 current))
  (set-as-offset-from! (the-as hud-sprite (-> this strings 0 pos)) (the-as vector4w (-> this sprites)) -12 8)
  ((method-of-type hud draw) this)
  0
  (none)
  )

(defmethod draw ((this stadium-board1-hud-dual-score))
  (set-hud-piece-position!
    (the-as hud-sprite (-> this sprites))
    480
    140
    )
  (set-hud-piece-position!
    (-> this sprites 1)
    480
    210
    )
  (format (clear (-> this strings 0 text)) "~D" (-> this values 0 current))
  (format (clear (-> this strings 1 text)) "~D" (-> this values 1 current))
  (set-as-offset-from! (the-as hud-sprite (-> this strings 0 pos)) (the-as vector4w (-> this sprites)) -12 8)
  (set-as-offset-from! (the-as hud-sprite (-> this strings 1 pos)) (the-as vector4w (-> this sprites 1)) -12 8)
  ((method-of-type hud draw) this)
  0
  (none)
  )

(defmethod update-values ((this stadium-board1-hud-dual-score))
  (set! (-> this values 0 target) (mp-stadium-board1-hud-local-score))
  (set! (-> this values 1 target) (mp-stadium-board1-hud-remote-score))
  ((method-of-type hud update-values) this)
  0
  (none)
  )

(defmethod init-callback ((this stadium-board1-hud-dual-score))
  (set! (-> this gui-id)
        (add-process *gui-control* this (gui-channel hud-center-right) (gui-action hidden) (-> this name) 81920.0 0)
        )
  (logior! (-> this flags) (hud-flags show))
  (set! (-> this sprites 0 tex) (get-texture hud-scoreboard-01 level-default-minimap))
  (set! (-> this sprites 1 tex) (get-texture hud-scoreboard-01 level-default-minimap))
  (set! (-> this sprites 0 scale-x) 1.5)
  (set! (-> this sprites 1 scale-x) 1.5)
  (set! (-> this sprites 0 flags) (the-as uint 4))
  (set! (-> this sprites 1 flags) (the-as uint 4))
  (alloc-string-if-needed this 0)
  (set! (-> this strings 0 scale) 0.5)
  (set! (-> this strings 0 flags) (font-flags kerning right large))
  (set! (-> this strings 0 color) (stadium-board1-hud-local-color))
  (alloc-string-if-needed this 1)
  (set! (-> this strings 1 scale) 0.5)
  (set! (-> this strings 1 flags) (font-flags kerning right large))
  (set! (-> this strings 1 color) (stadium-board1-hud-remote-color))
  0
  (none)
  )

(defmethod update-values ((this stadium-board1-hud-main-green-score))
  (set! (-> this values 0 target) (mp-stadium-board1-hud-local-score))
  ((method-of-type hud update-values) this)
  0
  (none)
  )

(defmethod init-callback ((this stadium-board1-hud-main-green-score))
  (set! (-> this gui-id)
        (add-process *gui-control* this (gui-channel hud-center-right) (gui-action hidden) (-> this name) 81920.0 0)
        )
  (logior! (-> this flags) (hud-flags show))
  (set! (-> this sprites 0 tex) (get-texture hud-scoreboard-01 level-default-minimap))
  (set! (-> this sprites 0 scale-x) 1.5)
  (set! (-> this strings 0 scale) 0.5)
  (set! (-> this sprites 0 flags) (the-as uint 4))
  (alloc-string-if-needed this 0)
  (set! (-> this strings 0 flags) (font-flags kerning right large))
  (set! (-> this strings 0 color) (font-color green))
  0
  (none)
  )

