;;-*-Lisp-*-
(in-package goal)

;; name: mod-custom-code.gc
;; name in dgo: mod-custom-code
;; dgos: TODO

;; --- Multiplayer Externs ---
(define-extern multiplayer-client-tick (function none))
(define-extern multiplayer-network-tick (function none))
(define-extern *dproc* process)
(define-extern activate-progress (function process symbol none))

(define *mp-open-demo-end-progress* #f)
(define *mp-demo-end-menu-active?* #f)
(define *mp-palace-exited-waiting?* #f)

(defun open-demo-end-progress ()
  (when (and *dproc* (nonzero? *dproc*))
    (activate-progress *dproc* 'demo-end)
    (set! *mp-demo-end-menu-active?* #t)
    (set! *mp-palace-exited-waiting?* #f)
  )
)

(defun demo-guard-tick ()
  (when *mp-open-demo-end-progress*
     (open-demo-end-progress)
     (set! *mp-open-demo-end-progress* #f)
  )

  (when (and 
             (not *debug-segment*)
             *target*
             (nonzero? *target*)
             (task-node-closed? (game-task-node palace-boss-resolution)))
    (let ((current-level (level-get-target-inside *level*)))
      (when (and current-level (nonzero? current-level))
        (let ((level-name (-> current-level name)))
          (cond
            ((member level-name '(palboss palroof palcab palshaft throne palent palout lbrnermk lashthrn lthrnout))
              (set! *mp-palace-exited-waiting?* #t)
            )
            (else
              (when (and *mp-palace-exited-waiting?* (not *mp-demo-end-menu-active?*))
                (open-demo-end-progress)
              )
            )
          )
        )
      )
    )
  )
)

;;;;;;;;;;;;;;;;;;;;;;;;;;
;; What is this file for.
;;;;;;;;;;;;;;;;;;;;;;;;;;

#| This file contains function defenitions that are pre placed in the mod base,
so if you place custom code inside of these functions, it will exectue based on
the name of the function, for example, if you place (set! (-> *game-info* fuel) (+ (-> *game-info* fuel) 1))
to the function named runs-on-orb-pickup, then jaks powercell count will increase each time you collect
an orb |#


;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Begin function defintions.
;;;;;;;;;;;;;;;;;;;;;;;;;;

(defun runs-every-frame ()
  ;; --- Multiplayer Tick ---
  ;; Runs Polling, Interpolation, and high-frequency state logic
  (multiplayer-client-tick)
  (demo-guard-tick)
  (none)
  )

(defun runs-on-gem-pickup ()
  ;; Code here runs on any scout fly pickup

  (none)
  )

(defun runs-on-task-close ()


