    )

  (none)
  )

(defun runs-on-jak-spawn ()
  ;; Code here runs every time jak spawns (loading a file new game or death)
  (set! *mp-demo-end-menu-active?* #f)
  (set! *mp-palace-exited-waiting?* #f)
  (if (and *local-info*
           (nonzero? (the-as uint *local-info*))
           (= (-> *local-info* role) 1)
           (nonzero? (-> *local-info* sync-flag)))
      (begin
        (set! *multi-sync-enabled?* #f)
        (format 0 "[GOAL] Jak spawned during full sync. Keeping multiplayer sync disabled.~%")
        )
      (begin
        (set! *multi-sync-enabled?* #t)
        (format 0 "[GOAL] Jak spawned! Enabling multiplayer sync.~%")
        )
      )

  ;; Update status to IN_GAME (6) if we are connected and fully synced
  (let ((status (pc-multi-get-status)))
    (when (>= status 3)
      (if (mp-is-jak?)
          (begin
            (pc-multi-set-status 6)
            (set! *multi-last-send-time* 0)
            (mp-arm-mission-failed-full-sync-after-spawn)
            )
          (begin
            ;; Client side: only update/arm if we are already in-game and finished full sync
            (when (and *local-info* (nonzero? *local-info*) (= status 6) (zero? (-> *local-info* sync-flag)))
              (set! *multi-last-send-time* 0)
              (mp-arm-mission-failed-full-sync-after-spawn)
              )
            )
          )
      )

    ;; Only auto-initialize if we aren't already connected/connecting
    (when (zero? status)
      (let ((host-arg (pc-multi-get-command-line-arg "-mp-host"))
            (client-arg (pc-multi-get-command-line-arg "-mp-client")))
        (cond
          ;; 1. Priority: CLI Host Flag
          ((and host-arg (nonzero? (-> host-arg allocated-length)))
           (format 0 "[MP-Auto] Hosting via CLI argument.~%")
           (pc-multi-setup-host)
           (pc-multi-set-status 6)
           (set! (-> *local-info* sync-flag) (the-as uint 1))
           )
          ;; 2. Priority: CLI Client Flag
          ((and client-arg (nonzero? (-> client-arg allocated-length)))
           (format 0 "[MP-Auto] Connecting via CLI argument.~%")
           (pc-multi-setup-client client-arg 26210)
           )

          ;; 3. Priority: Saved Setting
          ((-> *pc-settings* mp-hosting-mode?)
           (format 0 "[MP-Host] Hosting mode active (from settings). Initializing server...~%")
           (pc-multi-setup-host)
           (set! (-> *local-info* sync-flag) (the-as uint 1))
           )
          )
        )
      )
    )

  (none)
  )

(defun runs-on-jak-death ((death-event symbol))
  (case death-event
    (('dying)
      ;; Code here runs immediately every time jak dies, before any death animation or death cutscene

      )
    (('blackout)
      ;; Code here runs after jak dies (and any death cutscene finishes), during the blackout before he spawns

      )
    )

  (none)
  )


